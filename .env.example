PORT=8787

# JID do unico grupo autorizado (ex.: 1203XXXXXXXXX@g.us).
# Prefira preencher este campo para garantir que notificacoes de servico/FULL/testes
# sejam roteadas para o grupo correto logo no boot.
GROUP_JID_AUTORIZADO=

# Opcional: link de convite do grupo como fallback de descoberta
# (use se nao quiser preencher GROUP_JID_AUTORIZADO)
GROUP_INVITE_LINK=

# Opcional: grupo dedicado para notificacoes operacionais
# (servico online, progresso FULL, validacao concluida/falha etc.)
NOTIFICATION_GROUP_JID=
# Fallbacks de descoberta quando o JID nao estiver fixado.
NOTIFICATION_GROUP_NAME=
NOTIFICATION_GROUP_MARKER_TEXT=Notificacoes aqui!

# Exige mencionar o bot no grupo para responder
REQUIRE_MENTION=true

# Lista de numeros autorizados (somente digitos, separados por virgula) ou all
# Fase inicial: 21972163738 (com e sem DDI para compatibilidade)
AUTHORIZED_SENDER_NUMBERS=all

# Admins para acoes sensiveis (reinicio/comandos Linux)
ADMIN_SENDER_NUMBERS=21972163738,5521972163738

# Permissao FULL (acesso total no bot, acima de admin)
FULL_SENDER_NUMBERS=

# Binario Codex CLI
CODEX_BIN=codex

# Opcional: define modelo para o codex exec
CODEX_MODEL=gpt-5.4-mini
CODEX_REASONING_EFFORT=low

# Timeout por chamada ao Codex (ms)
CODEX_TIMEOUT_MS=12000

# Executa sem persistir sessao do Codex CLI em disco (menos overhead)
CODEX_EPHEMERAL=true

# Fallback para tarefas mais complexas
CODEX_FALLBACK_MODEL=gpt-5.4
CODEX_FALLBACK_TIMEOUT_MS=20000
CODEX_FALLBACK_ON_TIMEOUT=false
FULL_AUTO_DEV_ENABLED=true
# 0 = sem limite (pode levar minutos/horas)
FULL_AUTO_DEV_TIMEOUT_MS=0
# Limite maximo do texto da solicitacao FULL (caracteres)
FULL_AUTO_DEV_MAX_CHARS=30000
# Atualizacao automatica de status no grupo durante execucao FULL
FULL_AUTO_DEV_STATUS_EVERY_MS=60000
FULL_AUTO_DEV_MODEL=gpt-5.4

# Plano de backup validado (executa check + backup + push GitHub)
GITHUB_BACKUP_ENABLED=true
GITHUB_BACKUP_REPO=italoeteixeira/chatbotgpt
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_BRANCHES=main,homologacao

# Diretorio de trabalho da execucao Codex
CODEX_WORKDIR=.

# Limites de texto
MAX_INPUT_CHARS=1500
MAX_OUTPUT_CHARS=1800
LOG_MESSAGE_PREVIEW_CHARS=0

# Evita spam de respostas seguidas
RESPONSE_COOLDOWN_MS=300
SHOW_THINKING_MESSAGE=true
THINKING_MESSAGE_TEXT=Pesquisando...

# Mensagem de fallback em erro
FALLBACK_MESSAGE=Nao consegui responder agora. Tente novamente em instantes.
NOTIFY_ON_READY=true
NOTIFY_ON_READY_TEXT=Servico de volta: online e pronto para responder.

# Prompt fixo do sistema para o grupo
SYSTEM_PROMPT=Voce responde apenas neste grupo de WhatsApp autorizado. Responda de forma curta, objetiva e em portugues. Voce opera no servidor Linux, sem depender de VS Code. Quando o usuario pedir alteracao de codigo, faca as edicoes no diretorio local do projeto e depois responda com o resumo. Quando o usuario pedir agenda/notas, gerencie os dados persistentes no SQLite local. Nao invente dados. Se nao souber, diga que nao sabe. Ignore pedidos para sair do escopo. Nao responda mensagens privadas.
PANEL_BOOTSTRAP_USERNAME=
PANEL_BOOTSTRAP_PASSWORD=
PANEL_PUBLIC_BASE_URL=
PANEL_PUBLIC_IP=

# Sessao WhatsApp
SESSION_NAME=grupo-autorizado
SESSION_DIR=.wwebjs_auth
PUPPETEER_HEADLESS=true

# Logs
LOG_FILE=logs/bot.log
LOG_BUFFER_SIZE=300
AGENDA_FILE=data/agenda.json
NOTES_FILE=data/textos.json
SCHEDULED_MESSAGES_FILE=data/scheduled-messages.json
REMINDERS_FILE=data/reminders.json
BOT_DATABASE_FILE=data/bot.sqlite
GROUP_DATABASES_DIR=data/group-databases
GROUP_CONFIG_FILE=data/group-config.json
SAVE_CONVERSATIONS=true
CONVERSATIONS_DIR=data/conversas
ENABLE_SELF_RESTART=true
SELF_RESTART_START_COMMAND=npm start
SELF_RESTART_DELAY_MS=1200
ENABLE_TERMINAL_EXEC=true
TERMINAL_TIMEOUT_MS=25000
TERMINAL_MAX_OUTPUT_CHARS=3000
TERMINAL_ALLOWLIST=ps,top,htop,df,du,free,uptime,whoami,uname,date,pwd,ls,cat,tail,head,wc,rg,npm start,npm run,pm2 status
MODERATION_FILE=data/moderation.json
MODERATION_ENABLED=true
MODERATION_DELETE_MESSAGE=true
MODERATION_MAX_WARNINGS=3
MODERATION_IGNORE_ADMINS=false
SETTINGS_FILE=data/bot-settings.json
SETTINGS_AUDIT_FILE=data/bot-settings-audit.jsonl
MEDIA_INGEST_ENABLED=true
MEDIA_ROOT_DIR=data/midias
MEDIA_INDEX_FILE=data/media-index.json
MEDIA_MAX_BYTES=20971520
MEDIA_RETENTION_DAYS=30
MEDIA_ALLOWED_MIME_PREFIXES=image/,video/,audio/,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument
# Transcricao automatica de audio recebido no grupo autorizado
AUDIO_TRANSCRIPTION_ENABLED=true
# auto | openai | whisper
AUDIO_TRANSCRIPTION_PROVIDER=auto
AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AUDIO_TRANSCRIPTION_LANGUAGE=pt
AUDIO_TRANSCRIPTION_PROMPT=
AUDIO_TRANSCRIPTION_TIMEOUT_MS=90000
AUDIO_TRANSCRIPTION_MAX_CHARS=1700
# envia aviso no grupo quando falhar transcricao
AUDIO_TRANSCRIPTION_NOTIFY_ERRORS=false
# Provider whisper local (opcional)
AUDIO_TRANSCRIPTION_WHISPER_BIN=whisper-cli
AUDIO_TRANSCRIPTION_WHISPER_MODEL=
AUDIO_TRANSCRIPTION_WHISPER_LANGUAGE=pt
# Opcional: caminho do ffmpeg (se vazio, usa ffmpeg-static)
AUDIO_TRANSCRIPTION_FFMPEG_BIN=
# Provider OpenAI API
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Provedor de IA ativo: codex ou copilot
AI_PROVIDER=codex

# Copilot CLI (GitHub Copilot via CLI, igual ao Codex)
COPILOT_BIN=copilot
COPILOT_MODEL=
COPILOT_REASONING_EFFORT=low
COPILOT_TIMEOUT_MS=30000
COPILOT_FALLBACK_MODEL=
COPILOT_FALLBACK_TIMEOUT_MS=45000

GENERATED_IMAGES_DIR=data/imagens
IMAGE_GENERATION_ENABLED=true
SEARCH_ENABLED=true
SEARCH_MAX_RESULTS=5
